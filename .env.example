# ─── LLM CONFIGURATION ───
LLM_PROVIDER=groq  # groq | gemini
LLM_API_KEY=gsk_your_groq_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_CHAT_MODEL=llama-3.1-8b-instant

# Optional: Gemini Configuration
GEMINI_API_KEY=your_gemini_key_here
GEMINI_CHAT_MODEL=gemini-1.5-flash

# ─── VECTOR DB (QDRANT) ───
# For Qdrant Cloud (Recommended for Demo)
QDRANT_URL=https://your-cluster-url.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=legal_vn_200_docs
QDRANT_READ_ONLY=true

# For Local Qdrant (Uncomment and use with --profile local-db)
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=

# ─── INFRASTRUCTURE ───
REDIS_URL=redis://redis:6379/0

# ─── NOTEBOOK / DEV (Optional) ───
LEGAL_DENSE_MODEL=BAAI/bge-m3
QDRANT_LOCAL_COLLECTION=legal_vn_notebook
QDRANT_LOCAL_PATH=./local_qdrant_db/notebook_hybrid
