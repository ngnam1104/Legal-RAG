# ─── LLM CONFIGURATION (GROQ - FAST) ───
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_ROUTING_MODEL=llama-3.1-8b-instant
LLM_CORE_MODEL=llama-3.3-70b-versatile

# ─── GEMINI CONFIGURATION — CHẤT LƯỢNG CAO ───
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-flash

# ─── OLLAMA BACKUP ───
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b

# ─── VECTOR DB (QDRANT LOCAL - Docker) ───
QDRANT_URL=http://localhost:6335
QDRANT_COLLECTION=legal_rag_docs_5000
QDRANT_READ_ONLY=false

# ─── STORAGE (Ổ D:) ───
HF_HOME=D:/huggingface_cache
SENTENCE_TRANSFORMERS_HOME=D:/huggingface_cache/sentence_transformers

# ─── INFRASTRUCTURE ───
REDIS_URL=redis://localhost:6379/0
EMBEDDING_SERVER_URL=http://localhost:8001
