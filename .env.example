# ─── LLM CONFIGURATION (GROQ / GEMINI / OLLAMA) ───
# Khuyên dùng: Gemini cho chất lượng tốt nhất, Groq cho tốc độ nhanh nhất.
LLM_PROVIDER=gemini
LLM_API_KEY=YOUR_API_KEY_HERE
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_CHAT_MODEL=gemini-1.5-flash

# ─── VECTOR DB (QDRANT - LOCAL DOCKER) ───
# Chạy docker-compose up -d trước khi sử dụng.
QDRANT_URL=http://localhost:6335
QDRANT_COLLECTION=legal_rag_docs
QDRANT_READ_ONLY=false

# ─── STORAGE & CACHE (Nên để ở ổ có dung lượng lớn > 10GB) ───
# Chuyển sang đường dẫn tuyệt đối (Ví dụ: D:/huggingface_cache)
HF_HOME=./huggingface_cache
SENTENCE_TRANSFORMERS_HOME=./huggingface_cache/sentence_transformers

# ─── INFRASTRUCTURE ───
# Redis phục vụ cho Chat Memory (Short-term)
REDIS_URL=redis://localhost:6379/0

# ─── FRONTEND CONFIG ───
NEXT_PUBLIC_API_URL=http://localhost:8000/api
