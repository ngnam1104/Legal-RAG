# ==============================================================================
# HỆ THỐNG ON-PREMISE KHÉP KÍN (LOCAL & INTERNAL LAN)
# ==============================================================================

# ─── INTERNAL API (LLM & EMBEDDING) ───
LLM_PROVIDER=internal
LLM_API_KEY=
LLM_BASE_URL=http://10.9.3.75:30028/api/llama3/8b
LLM_ROUTING_MODEL=llama3
LLM_CORE_MODEL=llama3
INTERNAL_LLM_URL=http://10.9.3.75:30028/api/llama3/8b
INTERNAL_EMBEDDING_URL=http://10.9.3.75:30010/api/v1/embedding
INTERNAL_RERANKER_URL=http://10.9.3.75:30546/api/v1/reranking

# ─── LLM RETRY & BATCHING ───
LLM_RETRY_DELAY=3
LLM_MAX_RETRIES=3
LLM_MICRO_BATCH_SIZE=4
LLM_INTER_BATCH_SLEEP=3.0

# ─── RAG RETRIEVAL ───
MAX_CONTEXT_CHARS=50000
MAX_RETRIEVAL_HITS=20
LEGAL_DENSE_MODEL=BAAI/bge-m3

# ─── VECTOR DB (QDRANT LOCAL - Docker) ───
QDRANT_URL=http://localhost:6337
QDRANT_PATH=
QDRANT_API_KEY=
QDRANT_COLLECTION=legal_rag_docs_nam
QDRANT_READ_ONLY=false

# ─── ABLATION STUDY FLAGS ───
ENABLE_RERANK=true
ENABLE_GRADING=false
ENABLE_REFLECTION=false

# ─── GRAPH DB (NEO4J LOCAL - Docker) ───
NEO4J_URI=bolt://localhost:7688
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=u7aGQYEWeFJD-jyeHB4ATtoAud73PptW35M1RzFlT-0

# ==============================================================================
# TEST PIPELINE (500 health docs, separate DBs — keep prod data intact)
# Toggle by setting TEST_MODE=true/false in chunking_embedding.py
# ==============================================================================
# Qdrant: collection riêng, không đụng collection production
TEST_QDRANT_COLLECTION=legal_rag_test_yte_500
# Neo4j TEST container riêng (port 7689 bolt / 7476 browser) — KHÔNG đụng production
TEST_NEO4J_URI=bolt://localhost:7689
TEST_NEO4J_USERNAME=neo4j
TEST_NEO4J_PASSWORD=test_neo4j_pass
# Giới hạn số văn bản xử lý trong test run
TEST_SAMPLE_LIMIT=500

# ─── CHAT HISTORY DB (POSTGRESQL - Docker) ───
POSTGRES_URL=postgresql://legal_rag:legal_rag_secret@localhost:5435/legal_chat_history

# ─── CACHE & QUEUE ───
REDIS_URL=redis://localhost:6380/0

# ─── STORAGE (Ổ D:) ───
HF_HOME=D:/huggingface_cache
SENTENCE_TRANSFORMERS_HOME=D:/huggingface_cache/sentence_transformers
